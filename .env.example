# =============================================================================
# ChopBet — Project-wide Environment Variables Reference
# =============================================================================
# This file documents ALL environment variables used across the project.
#
# Backend (.env lives in /backend/.env):
#   cd backend && cp ../.env.example .env   ← then edit the values
#
# Frontend (Next.js picks up .env.local in /frontend):
#   cd frontend && cp ../.env.example .env.local  ← then edit the values
#
# Never commit any .env / .env.local file to version control.
# =============================================================================


# =============================================================================
# BACKEND  (place in backend/.env)
# =============================================================================

# --- Database ----------------------------------------------------------------
# PostgreSQL connection string (Neon / Supabase / Railway / Heroku compatible).
# "postgres://" is automatically rewritten to "postgresql://" at runtime.
DATABASE_URL=postgresql://user:password@host:5432/chopbet_db

# --- Google Gemini AI --------------------------------------------------------
# Primary API key — fixture extraction & prediction generation.
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_primary_gemini_api_key_here

# Fallback key — automatically used when the primary key is rate-limited (429).
FALLBACK_GEMINI_API_KEY=your_fallback_gemini_api_key_here

# Gemini model used by the fallback path (default: gemini-1.5-flash).
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# --- Admin / Security --------------------------------------------------------
# Protects all /admin/* endpoints (sent as the X-Admin-Key header).
# Generate a secret with:  openssl rand -hex 32
ADMIN_API_KEY=your_super_secret_admin_key_here

# --- CORS / Frontend ---------------------------------------------------------
# Allowed CORS origin for the frontend. Defaults to http://localhost:3000.
FRONTEND_URL=http://localhost:3000


# =============================================================================
# FRONTEND  (place in frontend/.env.local)
# =============================================================================

# URL of the running backend API.
# In development: http://localhost:8000
# In production:  https://your-backend-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
