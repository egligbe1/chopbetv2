# =============================================================================
# ChopBet Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# Never commit your .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Supports both "postgres://" and "postgresql://" prefixes (auto-corrected).
# Get this from your Neon / Supabase / Railway / Heroku dashboard.
DATABASE_URL=postgresql://user:password@host:5432/chopbet_db


# -----------------------------------------------------------------------------
# GOOGLE GEMINI AI
# -----------------------------------------------------------------------------
# Primary Gemini API key — used for fixture extraction & predictions.
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_primary_gemini_api_key_here

# Fallback Gemini API key — used when the primary key hits its quota (429).
# Can be a second Google account's key or a key under a different project.
FALLBACK_GEMINI_API_KEY=your_fallback_gemini_api_key_here

# Gemini model to use when the primary model is rate-limited.
# Defaults to "gemini-1.5-flash" if not set.
GEMINI_FALLBACK_MODEL=gemini-1.5-flash


# -----------------------------------------------------------------------------
# ADMIN / SECURITY
# -----------------------------------------------------------------------------
# Secret key used to authenticate admin API endpoints (/admin/*).
# Use a long, random string — e.g. generate with: openssl rand -hex 32
ADMIN_API_KEY=your_super_secret_admin_key_here


# -----------------------------------------------------------------------------
# CORS / FRONTEND
# -----------------------------------------------------------------------------
# The URL of the deployed frontend. Allowed as a CORS origin on the API.
# In development this defaults to http://localhost:3000 if not set.
FRONTEND_URL=http://localhost:3000
